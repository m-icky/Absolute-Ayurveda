{
  "name": "absolute-ayurveda-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "Frontend",
    "Backend"
  ],
  "scripts": {
    "frontend": "npm run dev -w Frontend",
    "backend": "npm run dev -w Backend",
    "dev": "npx concurrently \"npm run frontend\" \"npm run backend\"",
    "install-all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
